ALPACA_ENV=paper

# Option 1: set both pairs and let trading_bot.env.resolve_alpaca_env()
# pick the matching one based on ALPACA_ENV (paper | live).
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET=
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET=

# Option 2: set the resolved pair directly. resolve_alpaca_env() respects
# these if present, bypassing the paper/live selector.
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

BOT_LOG_DIR=logs
BOT_STATE_DIR=state

# Finnhub (market news + sentiment). Get a free key at https://finnhub.io.
FINNHUB_API_KEY=

# ntfy.sh push notifications. Topic names act as their own credential on
# the free tier (anyone with the name can subscribe to alerts or publish
# to the kill switch), so generate long random strings — e.g.
#   python -c "import secrets; print('bot-alerts-' + secrets.token_urlsafe(24))"
# If unset, the bot trades silently with no push notifications.
NTFY_TOPIC=
NTFY_KILL_TOPIC=
